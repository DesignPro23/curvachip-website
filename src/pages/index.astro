
---
// src/pages/index.astro
// HOME PAGE
// ─────────────────────────────────────────────────────────────
// If you have a Layout component, replace the raw <html> shell
// below with: import Layout from '../layouts/Layout.astro'
// and wrap the body content in <Layout title="..." description="...">.
// ─────────────────────────────────────────────────────────────

const title       = "Software Development for Apple Platforms | Curvachip";
const description = "Curvachip LLC crafts exceptional, privacy-first software for Apple platforms. Built by an indie developer who believes great apps should be secure, beautiful, and honest.";

const apps = [
  {
    name: "Shadow Task",
    tagline: "Focus & Track",
    blurb: "A Pomodoro timer with identifiable tasks, progress tracking, and personal quote prompts — all stored entirely on-device.",
    href: "/shadow-task",
    emoji: "🌑",
  },
  {
    name: "TipZap",
    tagline: "Tip Calculator",
    blurb: "Split dinner costs, round totals, and calculate tips in seconds. The number pad is built right in.",
    href: "/tipzap",
    emoji: "⚡",
  },
  {
    name: "StoneClip",
    tagline: "Rock Identifier",
    blurb: "Point your camera at any rock and get an AI-powered identification with full geological context, instantly.",
    href: "/stoneclip-rock-identifier",
    emoji: "🪨",
  },
];

const values = [
  {
    label: "User-Focused Design",
    body: "Every decision — layout, color, copy — is made with a single question in mind: does this make it easier for the user?",
    icon: "◎",
  },
  {
    label: "Privacy by Default",
    body: "On-device processing wherever possible. No silent collection. What stays on your device stays on your device.",
    icon: "◈",
  },
  {
    label: "Feedback-Driven",
    body: "Criticism is a gift. Every App Store review, every email, every bug report shapes the next update.",
    icon: "◬",
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://curvachip.com/" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="canonical" href="https://curvachip.com/" />
</head>
<body>

<!-- ── NAV ─────────────────────────────────────────────────── -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Curvachip home">
      <span class="logo-chip" aria-hidden="true">◈</span>
      <span class="logo-text">Curvachip</span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class="nav-link active">Home</a></li>
      <li><a href="/apps" class="nav-link">Apps</a></li>
      <li><a href="/privacy" class="nav-link">Privacy</a></li>
      <li><a href="/contact" class="nav-link">Contact</a></li>
      <li><a href="/about" class="nav-link">About</a></li>
    </ul>
  </div>
</nav>

<!-- ── HERO ────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="container hero-content">
    <p class="eyebrow">Apple Platforms · Est. 2024</p>
    <h1 class="hero-title">Software built<br /><em>around&nbsp;you</em></h1>
    <p class="hero-sub">
      Curvachip distributes privacy-first apps on the App Store — designed for clarity,
      built with care, and shaped by the people who use them.
    </p>
    <div class="hero-cta">
      <a href="/apps" class="btn btn-primary">Explore Apps</a>
      <a href="/about" class="btn btn-ghost">Our Story</a>
    </div>
  </div>
</section>

<!-- ── VALUES ──────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <h2 class="section-title">What we stand for</h2>
    <div class="values-grid">
      {values.map((v) => (
        <div class="value-card">
          <span class="value-icon" aria-hidden="true">{v.icon}</span>
          <h3 class="value-label">{v.label}</h3>
          <p class="value-body">{v.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── FEATURED APPS ───────────────────────────────────────── -->
<section class="section section-alt">
  <div class="container">
    <h2 class="section-title">Featured apps</h2>
    <p class="section-sub">Every app is built for a purpose — vetted, designed, and submitted to the App Store with intention.</p>
    <div class="apps-grid">
      {apps.map((app) => (
        <a href={app.href} class="app-card">
          <span class="app-emoji" aria-hidden="true">{app.emoji}</span>
          <div>
            <p class="app-tagline">{app.tagline}</p>
            <h3 class="app-name">{app.name}</h3>
            <p class="app-blurb">{app.blurb}</p>
          </div>
          <span class="app-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
    <div class="cta-row">
      <a href="/apps" class="btn btn-primary">See all apps</a>
    </div>
  </div>
</section>

<!-- ── TESTIMONIAL ─────────────────────────────────────────── -->
<section class="section">
  <div class="container testimonial-wrap">
    <blockquote class="testimonial">
      <p class="testimonial-quote">
        "We all enjoyed and appreciated Michael's preparation, his earnest interest in listening,
        and his thoughtful dialogue … he is ready to GO!"
      </p>
      <footer class="testimonial-footer">
        <cite>
          Cathy Hayes — <a href="https://www.hayesstudio.com/home" target="_blank" rel="noopener">Hayes Inc.</a>
        </cite>
      </footer>
    </blockquote>
  </div>
</section>

<!-- ── FOOTER ──────────────────────────────────────────────── -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo-chip" aria-hidden="true">◈</span>
      <span class="logo-text">Curvachip</span>
      <p class="footer-tagline">Crafting exceptional software for Apple platforms.</p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/" class="footer-link">Home</a>
      <a href="/apps" class="footer-link">Apps</a>
      <a href="/privacy" class="footer-link">Privacy</a>
      <a href="/contact" class="footer-link">Contact</a>
      <a href="/about" class="footer-link">About</a>
    </nav>
    <div class="footer-social">
      <a href="https://github.com/Curvachip" class="social-link" target="_blank" rel="noopener" aria-label="GitHub">GH</a>
      <a href="https://x.com/curvachip" class="social-link" target="_blank" rel="noopener" aria-label="X / Twitter">𝕏</a>
      <a href="https://www.linkedin.com/company/curvachip" class="social-link" target="_blank" rel="noopener" aria-label="LinkedIn">in</a>
      <a href="https://www.instagram.com/curvachip/" class="social-link" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
      <a href="https://www.youtube.com/@curvachip" class="social-link" target="_blank" rel="noopener" aria-label="YouTube">YT</a>
      <a href="mailto:developer@curvachip.com" class="social-link" aria-label="Email">@</a>
    </div>
    <p class="footer-legal">
      Copyright © 2026 Curvachip LLC. All rights reserved.<br />
      <small>Apple is a trademark of Apple Inc. and is not affiliated with Curvachip LLC.</small>
    </p>
    <div class="footer-policy-links">
      <a href="/privacy-policy-curvachip" class="footer-link">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <a href="/terms-and-conditions-curvachip" class="footer-link">Terms of Use</a>
    </div>
  </div>
</footer>

</body>
</html>

<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ─────────────────────────────────────────────────────────
     All custom properties are defined on :root so any nested
     page or component can reference them. If you move content
     into a layout component, move the :root block there too.
     ═══════════════════════════════════════════════════════════ -->
<style is:global>
  /* ── TOKENS ── */
  :root {
    --cc-bg:        #080810;
    --cc-surface:   #10101E;
    --cc-border:    #1C1C32;
    --cc-blue:      #5B9CF6;
    --cc-blue-dim:  rgba(91, 156, 246, 0.12);
    --cc-violet:    #A78BFA;
    --cc-text:      #E8E8F0;
    --cc-muted:     #6A6A88;
    --cc-radius:    12px;
    --cc-max:       1120px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cc-bg);
    color: var(--cc-text);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }
  em { font-style: italic; }

  /* ── LAYOUT ── */
  .container {
    width: 100%;
    max-width: var(--cc-max);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
  }

  /* ── NAV ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--cc-border);
    background: rgba(8, 8, 16, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .nav-inner {
    max-width: var(--cc-max);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--cc-text);
  }
  .logo-chip {
    color: var(--cc-blue);
    font-size: 1.2rem;
    line-height: 1;
  }
  .nav-links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
  }
  .nav-link {
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--cc-muted);
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--cc-text);
    background: rgba(255,255,255,0.06);
  }
  @media (max-width: 600px) {
    .nav-links { display: none; }
  }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: opacity 0.15s, transform 0.15s, box-shadow 0.15s;
    cursor: pointer;
    border: none;
  }
  .btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-primary {
    background: var(--cc-blue);
    color: #07070F;
    box-shadow: 0 0 20px rgba(91,156,246,0.3);
  }
  .btn-primary:hover { box-shadow: 0 0 28px rgba(91,156,246,0.45); }
  .btn-ghost {
    background: transparent;
    color: var(--cc-text);
    border: 1px solid var(--cc-border);
  }
  .btn-ghost:hover { border-color: var(--cc-blue); color: var(--cc-blue); }
  .btn-store {
    background: var(--cc-surface);
    color: var(--cc-blue);
    border: 1px solid var(--cc-border);
    font-size: 0.825rem;
  }
  .btn-store:hover { background: var(--cc-blue-dim); border-color: var(--cc-blue); }

  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(5rem, 14vw, 9rem) 0 clamp(4rem, 10vw, 7rem);
    text-align: center;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 0%, rgba(91,156,246,0.06) 0%, transparent 65%),
      linear-gradient(rgba(91,156,246,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(91,156,246,0.035) 1px, transparent 1px);
    background-size: auto, 44px 44px, 44px 44px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 0%, black 40%, transparent 100%);
    pointer-events: none;
  }
  .hero-content { position: relative; }
  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cc-blue);
    margin-bottom: 1.5rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(91,156,246,0.25);
    border-radius: 99px;
    background: rgba(91,156,246,0.07);
  }
  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.08;
    color: var(--cc-text);
    margin-bottom: 1.5rem;
  }
  .hero-title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--cc-blue), var(--cc-violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    max-width: 560px;
    margin-inline: auto;
    color: var(--cc-muted);
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
  }
  .hero-cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── SECTIONS ── */
  .section {
    padding: clamp(4rem, 9vw, 7rem) 0;
  }
  .section-alt { background: var(--cc-surface); }
  .section-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }
  .section-sub {
    color: var(--cc-muted);
    max-width: 520px;
    margin-bottom: 3rem;
    font-size: 1rem;
  }

  /* ── VALUES ── */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .value-card {
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 2rem 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .value-card:hover {
    border-color: rgba(91,156,246,0.4);
    box-shadow: 0 0 24px rgba(91,156,246,0.07);
  }
  .value-icon {
    display: block;
    font-size: 1.5rem;
    color: var(--cc-blue);
    margin-bottom: 1rem;
    line-height: 1;
  }
  .value-label {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  .value-body { color: var(--cc-muted); font-size: 0.9rem; }

  /* ── APPS GRID ── */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .app-card {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 1rem;
    align-items: start;
    background: var(--cc-bg);
    border: 1px solid var(--cc-border);
    border-radius: var(--cc-radius);
    padding: 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  .app-card:hover {
    border-color: rgba(91,156,246,0.4);
    box-shadow: 0 0 20px rgba(91,156,246,0.08);
  }
  .app-emoji {
    font-size: 1.75rem;
    line-height: 1;
    margin-top: 0.15rem;
  }
  .app-tagline {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cc-blue);
    margin-bottom: 0.2rem;
  }
  .app-name {
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .app-blurb { color: var(--cc-muted); font-size: 0.85rem; }
  .app-arrow {
    color: var(--cc-muted);
    margin-top: 0.25rem;
    transition: color 0.15s, transform 0.15s;
  }
  .app-card:hover .app-arrow { color: var(--cc-blue); transform: translateX(3px); }

  .cta-row { text-align: center; }

  /* ── TESTIMONIAL ── */
  .testimonial-wrap {
    max-width: 700px;
  }
  .testimonial {
    border-left: 3px solid var(--cc-blue);
    padding-left: 2rem;
  }
  .testimonial-quote {
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    font-style: italic;
    color: var(--cc-text);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .testimonial-footer cite {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--cc-muted);
  }
  .testimonial-footer a { color: var(--cc-blue); }

  /* ── FOOTER ── */
  .footer {
    border-top: 1px solid var(--cc-border);
    padding: 3.5rem 0 2rem;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .footer-tagline {
    color: var(--cc-muted);
    font-size: 0.85rem;
    width: 100%;
    margin-top: 0.25rem;
  }
  .footer-links, .footer-social {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .footer-link {
    font-size: 0.85rem;
    color: var(--cc-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .footer-link:hover { color: var(--cc-text); }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--cc-border);
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cc-muted);
    transition: color 0.15s, border-color 0.15s;
  }
  .social-link:hover { color: var(--cc-blue); border-color: var(--cc-blue); }
  .footer-legal {
    font-size: 0.78rem;
    color: var(--cc-muted);
    line-height: 1.7;
  }
  .footer-policy-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--cc-muted);
  }

  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition: none !important; animation: none !important; }
  }
</style>